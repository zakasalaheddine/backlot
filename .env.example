# Copy to .env and fill in. .env is gitignored.

# --- Replicate (default image backend) ---
REPLICATE_API_TOKEN=r8_your_token_here

# --- Provider selection (swap hosts without touching skills) ---
# Which backend serves each capability. Only "replicate" ships in v0.
BACKLOT_IMAGE_PROVIDER=replicate
BACKLOT_VIDEO_PROVIDER=replicate

# --- Model slugs (override to pin versions or move to a fork) ---
BACKLOT_NANO_BANANA_MODEL=google/nano-banana
# Seedance is v1 (video). Left here so the seam is documented.
BACKLOT_SEEDANCE_MODEL=bytedance/seedance-1-pro
