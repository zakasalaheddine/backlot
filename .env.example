# Copy to .env and fill in. .env is gitignored.

# --- Replicate (default image/video host) ---
REPLICATE_API_TOKEN=r8_your_token_here

# --- Capability registry -----------------------------------------------------
# Which model serves each capability lives in providers/models.json. Inspect and
# swap with:  python scripts/models.py list | inspect | set
# Per-capability overrides (written by `models.py set`, or set them by hand):
#   BACKLOT_<CAPABILITY>_MODEL     registry key or raw host slug (pinned
#                                  '<slug>:<versionhash>' keeps its profile)
#   BACKLOT_<CAPABILITY>_PROVIDER  stub | auto | <backend module name>
# Examples:
# BACKLOT_VIDEO_I2V_MODEL=seedance-2.0
# BACKLOT_IMAGE_COMPOSITE_PROVIDER=stub
# BACKLOT_AUDIO_TTS_PROVIDER=stub

# --- Legacy aliases (still honoured, used when no capability var is set) ---
# BACKLOT_IMAGE_PROVIDER=replicate       # applies to image.*
# BACKLOT_VIDEO_PROVIDER=replicate       # applies to video.i2v
# BACKLOT_NANO_BANANA_MODEL=google/nano-banana
# BACKLOT_SEEDANCE_MODEL=bytedance/seedance-1-pro
# BACKLOT_SEEDANCE_MODEL=bytedance/seedance-2.0
